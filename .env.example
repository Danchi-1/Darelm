# Darelm Production Environment Variables
# Copy this file to .env on your ECS server and fill in the actual values

# Database
SQLALCHEMY_DATABASE_URI=postgresql://user:password@host/dbname

# Authentication
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SECRET_KEY=generate_a_very_long_secure_random_string

# Mail
MAIL_USERNAME=your-smtp-email@example.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=no-reply@darelm.com

# AI Exec
E2B_API_KEY=e2b_your_production_key

# Security
# Set this to the frontend URL hosted on OSS (e.g., https://app.darelm.com)
CORS_ORIGINS=["https://app.darelm.com"]
